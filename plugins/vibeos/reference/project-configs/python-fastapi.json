{
  "_description": "Example project config for a Python FastAPI project",
  "project": {
    "name": "Example FastAPI Service",
    "slug": "example-fastapi",
    "description": "REST API service built with FastAPI",
    "repo_url": ""
  },
  "stack": {
    "language": "python",
    "framework": "fastapi",
    "source_dirs": ["src", "app"],
    "test_dir": "tests",
    "package_manager": "pip",
    "database": "postgresql"
  },
  "governance": {
    "team_size": "small",
    "compliance_targets": ["owasp"],
    "wo_dir": "docs/planning",
    "frozen_files": [],
    "production_urls": ["https://api.example.com"]
  },
  "agent": {
    "cloud_provider": "aws",
    "ci_cd_platform": "github-actions",
    "mcp_servers": ["none"]
  },
  "architecture_rules": [
    {
      "name": "api-purity",
      "type": "forbidden_imports",
      "description": "API routes cannot import from data layer",
      "source": "src/api/",
      "forbidden": ["src/models/", "src/db/"]
    },
    {
      "name": "no-raw-sql",
      "type": "forbidden_patterns",
      "description": "Use parameterized queries only",
      "pattern": "cursor\\.execute\\(\\s*f[\"']|execute\\(.*%s.*%",
      "paths": ["src/"]
    }
  ]
}
