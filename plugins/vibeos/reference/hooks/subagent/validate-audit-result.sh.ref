#!/bin/bash
# <!-- OPTIONAL: Include if project uses multi-agent workflows (subagents) -->
# Subagent Hook: Validate Audit Result
# Validates output from audit subagents. Blocks on FAIL or CRITICAL findings.
#
# Hook type: SubagentStop (matcher: .*)
# Response format: JSON with decision = allow|block
#
# Handles two message formats:
#   1. Structured: { "type": "audit_result", "decision": "PASS|FAIL", "findings": [...] }
#   2. Legacy: Simple PASS/FAIL in result JSON
#
# Framework version: 1.0.0

INPUT=$(cat)
AGENT_TYPE=$(echo "$INPUT" | jq -r '.agent_type // empty' 2>/dev/null || echo "")
RESULT=$(echo "$INPUT" | jq -r '.result // empty' 2>/dev/null || echo "")

# Try structured audit_result format
MSG_TYPE=$(echo "$RESULT" | jq -r '.type // empty' 2>/dev/null || echo "")

if [ "$MSG_TYPE" = "audit_result" ]; then
  DECISION=$(echo "$RESULT" | jq -r '.decision // empty' 2>/dev/null || echo "")
  WO=$(echo "$RESULT" | jq -r '.wo // "unknown"' 2>/dev/null || echo "unknown")

  # Check for CRITICAL severity findings
  CRITICAL_COUNT=$(echo "$RESULT" | jq '[.findings[]? | select(.severity == "CRITICAL")] | length' 2>/dev/null || echo "0")

  if [ "$DECISION" = "FAIL" ] || [ "$CRITICAL_COUNT" -gt 0 ]; then
    FINDING_COUNT=$(echo "$RESULT" | jq '.findings | length' 2>/dev/null || echo "0")
    HIGH_COUNT=$(echo "$RESULT" | jq '[.findings[]? | select(.severity == "HIGH")] | length' 2>/dev/null || echo "0")
    SUMMARY="$WO audit: $FINDING_COUNT findings ($CRITICAL_COUNT critical, $HIGH_COUNT high)"

    cat << EOF
{
  "decision": "block",
  "reason": "Audit FAILED for $WO. $SUMMARY. Address CRITICAL and HIGH findings before proceeding."
}
EOF
    exit 0
  fi

  echo '{"decision": "allow"}'
  exit 0
fi

# Legacy format: check agent_type for audit pattern
if echo "$AGENT_TYPE" | grep -qiE '(audit|review|validate)'; then
  DECISION=$(echo "$RESULT" | jq -r '.decision // empty' 2>/dev/null || echo "")

  if [ "$DECISION" = "FAIL" ]; then
    FINDINGS=$(echo "$RESULT" | jq -r '.findings // []' 2>/dev/null || echo "[]")
    cat << EOF
{
  "decision": "block",
  "reason": "Audit FAILED. Findings: $FINDINGS"
}
EOF
    exit 0
  fi
fi

echo '{"decision": "allow"}'
