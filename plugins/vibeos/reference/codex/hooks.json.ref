{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.vibeos/scripts/detect-runtime-capabilities.sh\" --project-dir \"$(git rev-parse --show-toplevel)\"",
            "timeout": 30,
            "statusMessage": "Detecting VibeOS runtime capabilities"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/governance-guard-codex.sh\"",
            "timeout": 10,
            "statusMessage": "Checking VibeOS governance"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/worktree-bash-guard.sh\"",
            "timeout": 5,
            "statusMessage": "Checking VibeOS worktree safety"
          }
        ]
      },
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/secret-scan-codex.sh\"",
            "timeout": 5,
            "statusMessage": "Scanning edit for secrets"
          },
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/worktree-scope-guard.sh\"",
            "timeout": 5,
            "statusMessage": "Checking VibeOS file territory"
          }
        ]
      }
    ]
  }
}
