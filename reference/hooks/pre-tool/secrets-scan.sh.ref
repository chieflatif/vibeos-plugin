#!/bin/bash
# <!-- REQUIRED -->
# Pre-Tool Hook: Secrets Scan
# Blocks Edit/Write operations that contain hardcoded secrets.
#
# <!-- ADAPT: Add project-specific secret patterns (e.g., Supabase, Stripe, custom API keys) -->
#
# Hook type: PreToolUse (matcher: Edit|Write)
# Response format: JSON with hookSpecificOutput.permissionDecision = allow|deny
#
# Framework version: 1.0.0

INPUT=$(cat)
CONTENT=$(echo "$INPUT" | jq -r '.tool_input.content // .tool_input.new_string // empty' 2>/dev/null || echo "")

# If no content to check, allow
if [ -z "$CONTENT" ]; then
  echo '{"hookSpecificOutput": {"permissionDecision": "allow"}}'
  exit 0
fi

# <!-- REQUIRED: These patterns detect the most common secret types -->

# AWS Access Keys
if echo "$CONTENT" | grep -qE 'AKIA[0-9A-Z]{16}'; then
  cat << 'EOF'
{
  "hookSpecificOutput": {
    "permissionDecision": "deny",
    "permissionDecisionReason": "BLOCKED: Potential AWS Access Key detected (AKIA...). Store secrets in .env and access via environment variables."
  }
}
EOF
  exit 0
fi

# OpenAI API keys
if echo "$CONTENT" | grep -qE 'sk-[a-zA-Z0-9]{48,}'; then
  cat << 'EOF'
{
  "hookSpecificOutput": {
    "permissionDecision": "deny",
    "permissionDecisionReason": "BLOCKED: Potential OpenAI API key detected (sk-...). Store secrets in .env and access via environment variables."
  }
}
EOF
  exit 0
fi

# Anthropic API keys
if echo "$CONTENT" | grep -qE 'sk-ant-[a-zA-Z0-9-]{90,}'; then
  cat << 'EOF'
{
  "hookSpecificOutput": {
    "permissionDecision": "deny",
    "permissionDecisionReason": "BLOCKED: Potential Anthropic API key detected (sk-ant-...). Store secrets in .env and access via environment variables."
  }
}
EOF
  exit 0
fi

# GitHub tokens
if echo "$CONTENT" | grep -qE 'ghp_[a-zA-Z0-9]{36}'; then
  cat << 'EOF'
{
  "hookSpecificOutput": {
    "permissionDecision": "deny",
    "permissionDecisionReason": "BLOCKED: Potential GitHub token detected (ghp_...). Store secrets in .env and access via environment variables."
  }
}
EOF
  exit 0
fi

# <!-- ADAPT: Add cloud-provider-specific patterns based on project config -->
# <!-- EXAMPLE: Stripe keys -->
# if echo "$CONTENT" | grep -qE 'sk_live_[a-zA-Z0-9]{24,}'; then
#   deny "Stripe live key detected"
# fi
# <!-- EXAMPLE: Azure connection strings -->
# if echo "$CONTENT" | grep -qE 'DefaultEndpointsProtocol=https;AccountName='; then
#   deny "Azure connection string detected"
# fi

# Generic hardcoded secret assignments
if echo "$CONTENT" | grep -qiE '(password|secret|api_key|apikey|auth_token|access_token)\s*[=:]\s*["\047][^"\047]{8,}["\047]'; then
  cat << 'EOF'
{
  "hookSpecificOutput": {
    "permissionDecision": "deny",
    "permissionDecisionReason": "BLOCKED: Potential hardcoded secret detected. Store secrets in .env and access via environment variables."
  }
}
EOF
  exit 0
fi

# .env file protection
FILE_PATH=$(echo "$INPUT" | jq -r '.tool_input.file_path // empty' 2>/dev/null || echo "")
if [[ "$FILE_PATH" == *".env"* && "$FILE_PATH" != *".env.example"* ]]; then
  cat << 'EOF'
{
  "hookSpecificOutput": {
    "permissionDecision": "deny",
    "permissionDecisionReason": "BLOCKED: .env files contain secrets and must not be edited programmatically."
  }
}
EOF
  exit 0
fi

# Allow the edit
echo '{"hookSpecificOutput": {"permissionDecision": "allow"}}'
